# ==============================================================================
# EffectRestoreStamina.gd
# 体力恢复效果实现
# 这是一个具体的消耗品效果实现，用于恢复玩家的体力值
# 继承自ConsumableEffect基类，展示了如何实现具体的消耗品效果
# 适用于初学者：这个例子展示了继承、属性控制和安全编码的实践
# ==============================================================================

# @tool装饰器使此类可以在Godot编辑器中被实例化和预览
# 这意味着你可以直接在编辑器中创建这个资源并预览其属性
@tool

# 定义类名为EffectRestoreStamina，使其他脚本可以直接引用此类
class_name EffectRestoreStamina

# 继承自ConsumableEffect基类，获得基础消耗品效果功能
# 通过继承，我们自动获得了use_sound属性和apply方法的框架
# 我们只需要实现apply方法中的具体逻辑
extends ConsumableEffect

# ========== 自定义属性 ==========

# 恢复的体力百分比，范围为0-100%
# @export_range装饰器限制了值的范围，并设置步长为1
# 这确保了percent值始终在合理范围内，防止设置过小或过大的值
# 默认为20%，表示使用此效果会恢复玩家20%的最大体力
@export_range(0,100,1) var 恢复百分比 := 20.0

# ========== 核心方法实现 ==========

# 实现父类的apply方法，定义具体的体力恢复逻辑
# @param _target: 效果作用的目标节点，通常是玩家节点
# @return: void - 无返回值
# 初学者提示：这个方法是在物品被使用时自动调用的
func apply(_target: Node) -> void:
	# 安全检查：使用has_method确认目标节点是否有restore_stamina_percent方法
	# 这种检查是防御性编程的好例子，可以防止运行时错误
	# 如果直接调用不存在的方法，游戏会崩溃
	if _target.has_method("restore_stamina_percent"):
		# 如果目标节点有该方法，调用它并传入体力恢复百分比
		# 通常_target是玩家节点，玩家节点中应该实现了这个方法来处理体力恢复
		_target.restore_stamina_percent(恢复百分比)
	else:
		# 如果目标节点没有该方法，记录一个警告
		# 警告不会导致游戏崩溃，但会在Godot的输出日志中显示
		# 这有助于开发者调试问题
		push_warning("目标节点没有restore_stamina_percent方法")

# ========== 工作原理解释 ==========
# 1. 当玩家使用带有此效果的消耗品时，系统会调用这个apply方法
# 2. 系统将玩家节点作为_target参数传入
# 3. 我们检查玩家节点是否有restore_stamina_percent方法
# 4. 如果有，我们调用该方法并传入要恢复的体力百分比
# 5. 玩家节点负责实际执行体力恢复的逻辑
# 
# 这种设计方式的优点：
# - 解耦合：效果类不直接访问玩家的内部组件
# - 灵活性：可以将相同效果应用到不同的对象上
# - 安全性：通过方法检查避免运行时错误
# - 可维护性：如果玩家节点的结构改变，只需确保它仍然提供相同的方法
# 
# 初学者实践建议：
# 当你实现新的消耗品效果时，遵循类似的安全检查模式
# 不要直接假设目标节点的内部结构，而是通过方法调用来实现功能
