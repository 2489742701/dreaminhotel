[internationalization]

locale/translation_remaps={}
locale/translations=PackedStringArray("res://translations/items.zh_CN.translation", "res://translations/items.en.translation")
locale/translation_add_builtin_strings_to_pot=true

[layer_names]

3d_render/layer_1="建筑"
3d_render/layer_5="怪物"

[physics]

3d/physics_engine="GodotPhysics3D"

[rendering]

textures/canvas_textures/default_texture_repeat=1
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
textures/default_filters/anisotropic_filtering_level=0
