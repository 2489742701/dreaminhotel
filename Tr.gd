# ==============================================================================
# Tr.gd
# 翻译工具脚本
# 提供物品名称翻译功能，方便游戏实现多语言支持
# 适用于初学者：了解如何在Godot中实现简单的翻译系统
# ==============================================================================

# 扩展自Node类，表示这是一个基本的场景节点
extends Node          # ← 必须加这一行

# 物品翻译方法
# @param key: String - 要翻译的文本键值
# @return: String - 翻译后的文本
# 初学者提示：这个方法是游戏中所有物品翻译的入口点
# 它调用Godot内置的tr()函数来获取翻译后的文本
func items(key: String) -> String:
	# tr()是Godot内置的翻译函数，会根据当前游戏语言设置返回对应的翻译文本
	# 如果你在项目中设置了翻译文件，这里会自动获取正确语言的文本
	# 如果没有对应的翻译，会返回原始键值
	return tr(key)
