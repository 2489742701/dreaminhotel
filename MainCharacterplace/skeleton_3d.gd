# 扩展自Skeleton3D类，这是Godot中用于3D骨骼动画和物理模拟的核心类
extends Skeleton3D

# @onready关键字确保在节点准备好后再获取引用
# sim变量保存对物理骨骼模拟器的引用，用于控制布娃娃物理效果
@onready var sim = $PhysicalBoneSimulator3D

# _ready方法在节点首次进入场景树时调用
# 初学者提示：这个方法通常用于初始化设置
func _ready():
	# 启动物理骨骼模拟，使骨骼能够响应物理效果
	# 这是启用布娃娃系统的关键步骤
	sim.physical_bones_start_simulation()

# _process方法每帧调用一次
# @param _delta: 自上一帧以来经过的时间（秒）
# 初学者提示：这里使用下划线前缀表示参数虽然接收但暂时未使用
func _process(_delta: float) -> void:
	# 当前留空，可以根据需要添加每帧执行的逻辑
	# 例如：监控骨骼状态、实现特殊动画效果等
	pass
